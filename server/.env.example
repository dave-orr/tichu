FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
ALLOWED_ORIGINS=https://tichu.squidbox.com
# Set to 1 only when running behind a trusted reverse proxy (e.g. nginx) so the
# X-Forwarded-For header can be trusted for per-IP connection limiting. Leave
# unset for direct/local deployments — otherwise clients can spoof their IP.
TRUST_PROXY=1
